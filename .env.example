# ─────────────────────────────────────────────────────────────────────────────
#  Nexo YR Secure — Variables de Entorno
#  Copia como `.env` y rellena con tus valores reales.
#  NUNCA subas el archivo `.env` al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Entorno ─────────────────────────────────────────────────────────────────
DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=config.settings.development

# Genera una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esta-clave-en-produccion

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos ───────────────────────────────────────────────────────────
# Desarrollo (SQLite, no requiere servidor):
DATABASE_URL=sqlite:///db.sqlite3

# Desarrollo con Docker Compose PostgreSQL:
# DATABASE_URL=postgres://ares:ares_dev@localhost:5432/ares_shop

# Producción (Render/Heroku proporciona DATABASE_URL automáticamente):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-de-16-caracteres
DEFAULT_FROM_EMAIL=noreply@aresseguridad.com
ORDER_FROM_EMAIL=pedidos@aresseguridad.com
# Opcional (por defecto = DEFAULT_FROM_EMAIL): remitente de errores del servidor
SERVER_EMAIL=noreply@aresseguridad.com

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Redis / Celery (opcional — requerido para tareas asíncronas) ─────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ─── Seguridad (solo producción) ─────────────────────────────────────────────
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
CSRF_TRUSTED_ORIGINS=https://tudominio.com

# ─── Información del comerciante ─────────────────────────────────────────────
SHOP_NAME=Nexo YR Secure
SHOP_BANK_NAME=Bancolombia
SHOP_BANK_ACCOUNT_NUMBER=000-000000-00
SHOP_BANK_ACCOUNT_TYPE=Ahorros
SHOP_BANK_HOLDER_NAME=Nexo YR Secure S.A.S.
SHOP_BANK_HOLDER_ID=900000000-1
SHOP_CONTACT_PHONE=+57 300 000 0000
SHOP_CONTACT_EMAIL=contacto@aresseguridad.com

# ─── Pasarelas de pago (dejar vacías si no se usan) ──────────────────────────

# Wompi (Colombia) — https://dashboard.wompi.co/
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_KEY=
WOMPI_EVENTS_KEY=

# PayU — https://developers.payulatam.com/
PAYU_API_KEY=
PAYU_API_LOGIN=
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_TEST_MODE=True

# MercadoPago — https://www.mercadopago.com.co/developers/
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

# Stripe — https://dashboard.stripe.com/
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Analítica (opcional) ─────────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=
